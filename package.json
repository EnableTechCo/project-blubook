{
  "name": "blubook-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true,maxRetries:10,retryDelay:200});}catch(e){if(e&&(e.code==='EBUSY'||e.code==='EPERM')){console.warn('[prebuild] .next is locked, continuing without full cleanup');}else{throw e;}}\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "pnpm lint && pnpm typecheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "debug:auth:partner": "node --env-file=.env.local scripts/debug-partner-auth.mjs",
    "debug:login:partner": "node scripts/debug-partner-login.mjs",
    "db:introspect": "node --env-file=.env.local scripts/introspect-db-and-apis.mjs",
    "email:test:onboarding": "node --env-file=.env.local scripts/send-test-onboarding-email.mjs",
    "seed:providers:mock": "node --env-file=.env.local scripts/seed-mock-provider-accounts.mjs"
  },
  "dependencies": {
    "@highcharts/react": "^5.1.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.75.5",
    "clsx": "^2.1.1",
    "highcharts": "^13.0.0",
    "lucide-react": "^0.511.0",
    "motion": "^12.40.0",
    "next": "^15.3.3",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.3",
      "esbuild": "^0.25.0",
      "postcss": "^8.5.10",
      "js-yaml": "^4.2.0"
    }
  }
}
